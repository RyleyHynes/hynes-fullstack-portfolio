{
  "name": "celium-root",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n BACKEND,FRONTEND \"cd backend/Celium.Api && dotnet run\" \"cd frontend && npm run dev\"",
    "build:backend": "dotnet build backend/Celium.sln",
    "build:frontend": "cd frontend && npm run build",
    "prepare": "husky install",
    "lint:frontend": "cd frontend && npm run lint",
    "test:frontend": "cd frontend && npm run test"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "husky": "^9.1.7"
  }
}
